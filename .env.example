# agent-memory-hub — copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- Supabase (Settings → API) ---
SUPABASE_URL="https://<YOUR_PROJECT_REF>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"   # public (anon) — respects RLS
SUPABASE_SECRET_KEY="sb_secret_xxx"             # SECRET (service_role) — used by hooks to write

# --- Backup module (optional): pg_dump via Supabase pooler ---
# Settings → Database → Connection string → "Session pooler" (IPv4).
PG_POOLER_HOST="aws-0-<region>.pooler.supabase.com"
PG_POOLER_PORT="5432"
PG_POOLER_USER="postgres.<YOUR_PROJECT_REF>"
PG_DATABASE="postgres"
BACKUP_DIR=""                                   # blank = <repo>/backups
KEEP="30"                                       # how many backups to keep

# --- pull-backups.sh (optional): pull backups from an always-on host to this machine ---
REMOTE_SSH="user@host"                          # e.g. ec2-user@1.2.3.4
SSH_KEY="/path/to/your-key.pem"
REMOTE_BACKUP_DIR="agent-memory-hub/backups/"

# --- Facts layer (OPTIONAL, bring-your-own-LLM). The core needs NO LLM. ---
# off (default) | ollama (local, free) | gemini (free tier) | openai (or compatible)
FACTS_LLM="off"
# gemini:  GEMINI_API_KEY="AIza..."   GEMINI_MODEL="gemini-2.5-flash"
# ollama:  OLLAMA_URL="http://localhost:11434"   OLLAMA_MODEL="qwen2.5:7b"
# openai:  OPENAI_API_KEY="sk-..."    OPENAI_BASE_URL="https://api.openai.com/v1"   OPENAI_MODEL="gpt-4o-mini"
