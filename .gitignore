# Secrets — never commit
.env*
!.env.example
*.key
*.pem
*.pgpass

# Python venv (used to apply schema / local tooling)
.venv/
__pycache__/
*.pyc

# Packaging build artifacts (pip install -e .)
*.egg-info/
build/
dist/

# Local DB backups (dumps are gzipped in backups/; keep tracked sql/ schema files)
backups/
*.sql.gz
*.ndjson.gz

# Hook runtime logs
*.log

# Content drafts (marketing) — not part of the public project
content/

# Personal weekly digest (generated from my own history) — never publish
DIGEST.md
PROFILE.md

# OS
.DS_Store
